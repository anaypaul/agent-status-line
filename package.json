{
  "name": "agent-status-line",
  "version": "0.1.0",
  "description": "A modular, agent-based status line for Claude Code",
  "type": "module",
  "bin": {
    "agent-status-line": "./dist/bin/agent-status-line.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx bin/agent-status-line.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "tsx bin/agent-status-line.ts preview",
    "benchmark": "tsx bin/agent-status-line.ts benchmark"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "smol-toml": "^1.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@inquirer/prompts": "^7.0.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "claude-code",
    "status-line",
    "statusline",
    "cli"
  ],
  "license": "MIT"
}
